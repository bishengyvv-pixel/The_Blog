# Environment Variables Template
# Copy this file to .env and fill in the values
# Note: Variables with "VITE_" prefix are exposed to the frontend code at BUILD TIME
#
# docker-compose 会自动读取同目录的 .env 文件进行变量替换
# 修改 .env 后需要重新构建: docker compose build frontend

# ====================
# FRONTEND (Vite - 构建时变量)
# ====================

# 后端 API 地址
# - 同机 nginx 代理: /api (浏览器通过 nginx 转发到 backend 容器)
# - 外部后端: http://your-server:3001/api (浏览器直接请求该地址)
VITE_API_BASE=/api

# ====================
# BACKEND (Express - 运行时变量)
# ====================

# Server port
PORT=3001

# Node environment: development | production
NODE_ENV=production

# Debug logging: true | false
DEBUG=false

# CORS allowed origins (comma-separated)
# 留空则允许所有来源
CORS_ORIGINS=
